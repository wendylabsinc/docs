{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://wendy.sh/schemas/template.schema.json",
    "title": "Wendy Template Schema",
    "description": "Defines multi-phase configuration questions for a wendy init template. Answers become Go template variables available in all rendered files.",
    "type": "object",
    "required": ["phases"],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "phases": {
            "type": "array",
            "description": "Ordered list of question phases. Each phase may be gated by a condition.",
            "items": { "$ref": "#/$defs/phase" }
        }
    },
    "$defs": {
        "phase": {
            "type": "object",
            "required": ["id", "questions"],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique identifier for this phase."
                },
                "title": {
                    "type": "string",
                    "description": "Heading printed before the phase's questions are shown."
                },
                "questions": {
                    "type": "array",
                    "description": "Questions to present in this phase.",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/question" }
                },
                "when": {
                    "$ref": "#/$defs/condition",
                    "description": "Condition that must be true for this phase to be shown. Absent means always show."
                }
            }
        },
        "question": {
            "type": "object",
            "required": ["id", "label", "type"],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Variable name. Becomes {{.ID}} in template files. Unique across all questions.",
                    "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                },
                "label": {
                    "type": "string",
                    "description": "Human-readable question text shown in the interactive prompt."
                },
                "type": {
                    "type": "string",
                    "description": "Prompt type.",
                    "enum": ["radio", "checkbox", "input"]
                },
                "options": {
                    "type": "array",
                    "description": "Selectable choices. Required for radio and checkbox; ignored for input.",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/option" }
                },
                "when": {
                    "$ref": "#/$defs/condition",
                    "description": "Condition that must be true for this question to be shown."
                },
                "required": {
                    "type": "boolean",
                    "description": "When true, empty input is rejected (input type only).",
                    "default": false
                },
                "default": {
                    "type": "string",
                    "description": "Default value pre-filled in the prompt (input type only)."
                },
                "secret": {
                    "type": "boolean",
                    "description": "Hint that the value is sensitive, e.g. an API token.",
                    "default": false
                }
            },
            "if": {
                "properties": { "type": { "enum": ["radio", "checkbox"] } }
            },
            "then": {
                "required": ["options"]
            }
        },
        "option": {
            "type": "object",
            "required": ["value", "label"],
            "additionalProperties": false,
            "properties": {
                "value": {
                    "type": "string",
                    "description": "Machine-readable value stored as the answer."
                },
                "label": {
                    "type": "string",
                    "description": "Human-readable text shown in the picker."
                }
            }
        },
        "condition": {
            "type": "object",
            "required": ["questionId"],
            "additionalProperties": false,
            "description": "Gates a phase or question on a previously collected answer. Exactly one of equals, in, or contains must be set.",
            "properties": {
                "questionId": {
                    "type": "string",
                    "description": "The id of a question answered earlier in the flow."
                },
                "equals": {
                    "type": "string",
                    "description": "Show when the answer equals this string exactly."
                },
                "in": {
                    "type": "array",
                    "description": "Show when the answer matches any value in this list.",
                    "minItems": 1,
                    "items": { "type": "string" }
                },
                "contains": {
                    "type": "string",
                    "description": "Show when the answer (comma-separated checkbox result) contains this value."
                }
            },
            "oneOf": [
                { "required": ["equals"], "not": { "required": ["in"] }, "properties": { "contains": false } },
                { "required": ["in"],     "not": { "required": ["equals"] }, "properties": { "contains": false } },
                { "required": ["contains"], "not": { "required": ["equals"] }, "properties": { "in": false } }
            ]
        }
    }
}
